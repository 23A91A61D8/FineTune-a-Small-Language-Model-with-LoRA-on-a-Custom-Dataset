# ──────────────────────────────────────────────────
#  .env.example  —  copy to .env and edit as needed
# ──────────────────────────────────────────────────

# HuggingFace Hub model to fine-tune
# Lightweight option  : TinyLlama/TinyLlama-1.1B-Chat-v1.0
# As per task spec    : unsloth/Llama-3.2-3B-Instruct
#                       mistralai/Mistral-7B-Instruct-v0.3
MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# Path to the training JSONL file
DATASET_PATH=dataset/training_data.jsonl

# Directory where loss_curve.png is saved
OUTPUT_DIR=output

# Directory where LoRA adapter weights are saved
ADAPTER_DIR=lora_adapter

# Training hyper-parameters
EPOCHS=3
BATCH_SIZE=2
LEARNING_RATE=2e-4

# LoRA configuration
LORA_RANK=16
LORA_ALPHA=32

# Tokenisation
MAX_SEQ_LENGTH=512

# Inference
MAX_NEW_TOKENS=150

# (Optional) HuggingFace token — needed for gated models like Mistral / Llama
# HUGGING_FACE_HUB_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
